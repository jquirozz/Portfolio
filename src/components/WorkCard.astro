---
const { side, info } = Astro.props;
const { title, description, link, langs, finished } = info;

import Link from "./utils/Link.astro";
import Icon from "./utils/Icon.astro";
---

<section class={`WorkCard ${side % 2 === 0 ? "left" : "right"}`}>
  <Link to={link}>
    <article>
      <header>
        <h2>{title}</h2>
        <p>{description}</p>
      </header>
      <div class="image">
        <img src={`/work/${title}/1.png`} alt={`${title} image`} />
      </div>
      <div class="langs">
        {langs.map((lang) => <Icon name={lang} size="1.75" />)}
      </div>
    </article>
  </Link>
</section>

<style>
  .WorkCard {
    flex: 1;
    display: flex;
  }

  article {
    position: relative;

    display: grid;
    gap: 1rem;
    padding: 1rem;

    min-width: 400px;
    max-width: 600px;
    width: 100%;

    background-color: #f5f5f5;
  }

  article header {
    display: grid;
    gap: 0;
  }
  article header h2 {
    text-transform: capitalize;
    font-size: 3rem;
    color: #000;
  }
  article header p {
    color: #555;
  }

  article .image {
    overflow: hidden;
    width: 100%;
    aspect-ratio: 16/9;

    box-shadow: 0 5px 10px #0005;
    border-radius: 5px;

    background-color: #111;
  }
  article .image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  article .langs {
    --mainColor: #333;
    --width: 10rem;
    --height: 2.75rem;

    --bottomColor: #222;
    --bottomOutside: 6;
    --bottomWidth: calc(var(--width) / var(--bottomOutside));
    --bottomHeight: calc(var(--height) * 0.5);

    position: absolute;

    bottom: var(--bottomHeight);
    right: calc(var(--width) / (-1 * var(--bottomOutside)));

    width: var(--width);
    height: var(--height);

    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem;

    border-radius: 5px;
    border-bottom-right-radius: 0;

    background-color: var(--mainColor);
  }
  article .langs::before {
    content: "";

    position: absolute;
    top: var(--height);
    right: 0;

    width: 0;
    height: 0;
    border-bottom: var(--bottomHeight) solid transparent;
    border-left: var(--bottomWidth) solid var(--bottomColor);
  }

  .left {
    padding-right: 2rem;
    transform: translateX(-100%);
  }
  .left .space {
    order: 1;
  }
  .left article {
    border-top-right-radius: 10px;
  }

  .right {
    justify-content: flex-end;
    padding-left: 2rem;
    transform: translateX(100%);
  }
  .right article {
    border-top-left-radius: 10px;
  }
  .right article .langs {
    right: auto;
    left: calc(var(--width) / (-1 * var(--bottomOutside)));

    justify-content: flex-end;

    border-bottom-right-radius: 5px;
    border-bottom-left-radius: 0;
  }
  .right article .langs::before {
    left: 0;
    border-left: none;
    border-right: var(--bottomWidth) solid var(--bottomColor);
  }


  @media (max-width: 500px) {
    article {
      min-width: 260px;
    }
  }
</style>

<script is:inline>
  var cards = gsap.utils.toArray(".WorkCard");

  cards.forEach((card) => {
    gsap.to(card, {
      x: 0,
      y: 0,
      duration: 0.3,
      ease: "expoScale(0.5,7,none)",

      scrollTrigger: {
        trigger: card,
        start: "top +=75%",
        scrub: false,
        markers: false,
      },
    });
  });
</script>
